          "section": "Chapter VII",
          "type": "technical",
          "aws_controls": ["CloudTrail", "CloudWatch Logs", "S3 access logging", "Audit Manager"],
          "config_rules": ["cloudtrail-enabled", "cloud-trail-log-file-validation-enabled", "cloud-trail-encryption-enabled", "cloudwatch-log-group-encrypted", "s3-bucket-logging-enabled"],
          "guardrails": ["AWS-GR_CLOUDTRAIL_ENABLED", "AWS-GR_CLOUDTRAIL_VALIDATION_ENABLED", "AWS-GR_AUDIT_BUCKET_LOGGING_ENABLED", "AWS-GR_LOG_GROUP_ENCRYPTED"]
        }
      }
    },
