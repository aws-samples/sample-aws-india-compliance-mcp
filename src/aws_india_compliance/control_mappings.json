  "update_history": [
    {
      "date": "2026-04-30",
      "framework": "dpdp",
      "source_url": "https://egazette.gov.in/WriteReadData/2025/263757.pdf",
      "circular_date": "2025-11-14",
      "changes_applied": 18,
      "summary": "Updated DPDP mappings to incorporate Rules 2025 (notified Nov 14, 2025). Key changes: Rule 3 standalone privacy notices, Rule 4 Consent Manager framework with 7-year retention, Rule 6 prescriptive security safeguards with mandatory encryption/masking/1-year log retention, Rule 7 stricter breach notification (no threshold, dual notification, immediate + 72hr), Rule 8 prescriptive data retention with erasure timelines and 48hr warnings, Rules 10-12 verifiable parental consent with virtual identity tokens, Rule 13 mandatory annual DPIA/audits/algorithmic assessments for SDFs."
    }
  ]
